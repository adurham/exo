    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
      "fieldConfig": { "defaults": { "color": { "mode": "palette-classic" }, "custom": { "axisLabel": "bytes", "drawStyle": "line", "fillOpacity": 10, "lineInterpolation": "linear", "lineWidth": 2, "pointSize": 0, "showPoints": "never", "spanNulls": false, "stacking": { "group": "A", "mode": "none" } }, "unit": "bytes" } },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 27 },
      "id": 8,
      "options": { "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "bottom", "showLegend": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "exo_memory_ram_used_bytes",
          "legendFormat": "used · {{node_id}}",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_VICTORIAMETRICS}" },
          "expr": "exo_memory_ram_total_bytes",
          "legendFormat": "total · {{node_id}}",
          "refId": "B"
        }
